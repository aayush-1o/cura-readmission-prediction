# ═══════════════════════════════════════════════════════
# CareIQ Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────
POSTGRES_USER=careiq
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=careiq_warehouse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ───────────────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=   # leave empty for no-auth (dev), set in production

# ───────────────────────────────────────────────────────
# Airflow
# ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_UID=50000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=generate_random_32char_hex_here

# ───────────────────────────────────────────────────────
# pgAdmin
# ───────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@careiq.io
PGADMIN_PASSWORD=change_me

# ───────────────────────────────────────────────────────
# FastAPI Application
# ───────────────────────────────────────────────────────
SECRET_KEY=generate_a_strong_random_secret_key_here_minimum_32_chars
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
API_VERSION=v1
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ───────────────────────────────────────────────────────
# Frontend (Vite)
# ───────────────────────────────────────────────────────
# Base URL for the FastAPI backend. Used in frontend/src/services/api.js.
# Previously named VITE_API_URL in code — now aligned to this name.
VITE_API_BASE_URL=http://localhost:8000
# VITE_APP_ENV — reserved for future use (currently unused in codebase)
# VITE_APP_ENV=development

# ───────────────────────────────────────────────────────
# ML / Model Registry
# ───────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_REGISTRY_PATH=/opt/careiq/models
FEATURE_STORE_PATH=/opt/careiq/features
READMISSION_MODEL_NAME=careiq_readmission_v1
RISK_THRESHOLD_HIGH=0.65
RISK_THRESHOLD_MEDIUM=0.35

# ───────────────────────────────────────────────────────
# Data Paths
# ───────────────────────────────────────────────────────
DATA_RAW_PATH=./data/raw
DATA_STAGING_PATH=./data/staging
DATA_SYNTHETIC_PATH=./data/synthetic

# ───────────────────────────────────────────────────────
# Synthetic Data Generation
# ───────────────────────────────────────────────────────
SYNTHETIC_NUM_PATIENTS=10000
SYNTHETIC_NUM_ADMISSIONS=50000
SYNTHETIC_READMISSION_RATE=0.15
SYNTHETIC_SEED=42

# ───────────────────────────────────────────────────────
# Metabase
# ───────────────────────────────────────────────────────
METABASE_SITE_URL=http://localhost:3000

# ───────────────────────────────────────────────────────
# API Scaling
# ───────────────────────────────────────────────────────
API_WORKERS=4
API_RATE_LIMIT=100/minute

# ───────────────────────────────────────────────────────
# Monitoring & Alerting
# ───────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
REPORTS_DIR=./reports

# DQ Monitor thresholds
DQ_NULL_RATE_WARN=0.05
DQ_NULL_RATE_CRITICAL=0.20
DQ_ROW_COUNT_ZSCORE=3.0

# Model Monitor thresholds
MODEL_MONITOR_PSI_WARN=0.10
MODEL_MONITOR_PSI_CRITICAL=0.20
MODEL_MONITOR_AUC_MIN=0.78

# ───────────────────────────────────────────────────────
# CI/CD — GitHub Container Registry
# ───────────────────────────────────────────────────────
# Set as GitHub Actions secrets, not in .env
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_your_personal_access_token

# ───────────────────────────────────────────────────────
# Observability
# ───────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
