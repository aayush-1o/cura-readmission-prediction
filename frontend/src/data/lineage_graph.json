    {
      "id": "fact_admissions",
      "layer": "warehouse",
      "name": "fact_admissions",
      "rowCount": 51420,
      "droppedRows": 0,
      "lastUpdated": "2h ago",
      "note": "readmit_flag computed (30-day window)",
      "transformationSQL": "INSERT INTO fact_admissions\nSELECT\n  a.admission_id,\n  p.patient_key,\n  a.admit_date,\n  a.discharge_date,\n  a.los_days,\n  a.department,\n  d.icd_code AS primary_icd,\n  di.category AS diagnosis_category,\n  p.charlson_score,\n  -- 30-day readmission flag\n  EXISTS (\n    SELECT 1 FROM stg_admissions a2\n    WHERE a2.patient_key = p.patient_key\n      AND a2.admit_date BETWEEN a.discharge_date\n                             AND a.discharge_date + 30\n      AND a2.admission_id != a.admission_id\n  ) AS readmit_flag\nFROM stg_admissions a\nJOIN dim_patient p ON a.patient_key = p.patient_key\nJOIN stg_diagnoses d ON a.admission_id = d.admission_id AND d.diagnosis_seq = 1\nJOIN dim_diagnosis di ON d.icd_code = di.icd_code\nJOIN dim_date dd ON a.admit_date = dd.date_key",
      "schema": [
        {"col": "admission_id",       "type": "VARCHAR", "note": "PK"},
        {"col": "patient_key",        "type": "VARCHAR", "note": "FK → dim_patient"},
        {"col": "admit_date",         "type": "DATE",    "note": "FK → dim_date"},
        {"col": "los_days",           "type": "INT",     "note": ""},
        {"col": "department",         "type": "VARCHAR", "note": ""},
        {"col": "diagnosis_category", "type": "VARCHAR", "note": "CCS category"},
        {"col": "charlson_score",     "type": "INT",     "note": "Denormalized"},
        {"col": "readmit_flag",       "type": "BOOL",    "note": "30-day readmission"},
        {"col": "readmit_rate_30d",   "type": "NUMERIC", "note": "Rolling window rate"}
      ],
      "sampleRows": [
        {"admission_id": "A-0001", "los_days": 3, "charlson_score": 4, "readmit_flag": false},
        {"admission_id": "A-0002", "los_days": 5, "charlson_score": 1, "readmit_flag": true},
        {"admission_id": "A-0003", "los_days": 0, "charlson_score": 7, "readmit_flag": false}
      ],
      "upstream": ["stg_admissions", "dim_patient", "dim_diagnosis", "dim_date"],
      "downstream": ["mart_dashboard", "mart_risk_features", "fact_predictions"],
      "impact": [
        "⚠ ML scoring will use stale data",
        "⚠ Dashboard KPIs (readmission rate, LOS) will freeze",
        "⚠ 1,384 patients won't be scored until next run"
      ]
    },
