    {
      "id": "stg_admissions",
      "layer": "staging",
      "name": "stg_admissions",
      "rowCount": 51420,
      "droppedRows": 0,
      "lastUpdated": "2h ago",
      "transformationSQL": "SELECT\n  admission_id,\n  md5(patient_id) AS patient_key,\n  admit_date, discharge_date,\n  DATEDIFF('day', admit_date, discharge_date) AS los_days,\n  department, primary_icd,\n  CASE WHEN discharge_date IS NULL THEN TRUE ELSE FALSE END AS is_active\nFROM admissions\nWHERE admission_id IS NOT NULL",
      "schema": [
        {"col": "admission_id",  "type": "VARCHAR", "note": "PK"},
        {"col": "patient_key",   "type": "VARCHAR", "note": "FK → stg_patients"},
        {"col": "admit_date",    "type": "DATE",    "note": ""},
        {"col": "los_days",      "type": "INT",     "note": "Derived: discharge − admit"},
        {"col": "department",    "type": "VARCHAR", "note": ""},
        {"col": "is_active",     "type": "BOOL",    "note": "Current admission"}
