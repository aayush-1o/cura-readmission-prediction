    {
      "id": "stg_patients",
      "layer": "staging",
      "name": "stg_patients",
      "rowCount": 9987,
      "droppedRows": 13,
      "droppedReason": "DQ fail: missing gender or duplicate patient_id",
      "lastUpdated": "2h ago",
      "transformationSQL": "SELECT\n  md5(patient_id) AS patient_key,  -- PII hash\n  gender, ethnicity,\n  LEFT(zip_code, 3) AS zip3,  -- zip truncation\n  insurance,\n  DATE_PART('year', AGE(date_of_birth)) AS age_years\nFROM patients\nWHERE patient_id IS NOT NULL\n  AND gender IN ('M','F','O')",
      "schema": [
        {"col": "patient_key",  "type": "VARCHAR", "note": "MD5 hash of patient_id"},
        {"col": "gender",       "type": "CHAR(1)",  "note": "M/F/O"},
        {"col": "age_years",    "type": "INT",      "note": "Derived"},
        {"col": "zip3",         "type": "CHAR(3)",  "note": "Truncated for privacy"},
        {"col": "insurance",    "type": "VARCHAR",  "note": ""}
      ],
      "sampleRows": [
        {"patient_key": "a3f5...", "gender": "F", "age_years": 67, "zip3": "902"},
        {"patient_key": "b7c2...", "gender": "M", "age_years": 54, "zip3": "100"},
        {"patient_key": "e91a...", "gender": "F", "age_years": 72, "zip3": "606"}
      ],
      "upstream": ["patients_csv"],
      "downstream": ["dim_patient"],
      "impact": ["If this fails: dim_patient has stale data, Charlson scores may be wrong"]
